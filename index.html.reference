  <!-- ===================== SECTION 6: CONSERVATORY STYLES ===================== -->
  <section class="section bg-white">
    <div class="container">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:24px;margin-bottom:40px">
        <div style="max-width:620px">
          <div class="eyebrow reveal" data-delay="0">Every Style Covered</div>
          <h2 class="h-1 reveal" data-delay="0">We Cover Every Conservatory Style</h2>
        </div>
        <p class="reveal" data-delay="120" style="max-width:360px;color:#666">
          Not sure which style you have? <strong>We'll identify it for you — free.</strong>
        </p>
      </div>

      <div class="scroll-row">
        <div class="reveal" data-delay="0" style="width:320px">
          <div class="card-dark" style="background:white;color:var(--black);border:1.5px solid #eaeaea;box-shadow:0 4px 24px rgba(0,0,0,0.04)">
            <svg width="36" height="36" style="color:var(--orange);margin-bottom:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
            <h3 class="h-3">Victorian</h3>
            <p style="color:#555;margin-top:8px;font-size:14px">Classic three-faceted bay with a steeply pitched roof.</p>
          </div>
