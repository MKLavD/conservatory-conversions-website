        <strong style="font-family:'iBrand','Outfit',sans-serif;font-size:24px;text-transform:uppercase;letter-spacing:0.06em">Excellent</strong>
        <span style="color:var(--orange);font-size:24px;font-weight:800;font-family:'iBrand','Outfit',sans-serif">4.9/5</span>
        <span class="stars"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14.9 8.6 L22 9.5 L16.5 14.4 L18.2 21.5 L12 17.7 L5.8 21.5 L7.5 14.4 L2 9.5 L9.1 8.6 Z"/></svg><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14.9 8.6 L22 9.5 L16.5 14.4 L18.2 21.5 L12 17.7 L5.8 21.5 L7.5 14.4 L2 9.5 L9.1 8.6 Z"/></svg><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14.9 8.6 L22 9.5 L16.5 14.4 L18.2 21.5 L12 17.7 L5.8 21.5 L7.5 14.4 L2 9.5 L9.1 8.6 Z"/></svg><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14.9 8.6 L22 9.5 L16.5 14.4 L18.2 21.5 L12 17.7 L5.8 21.5 L7.5 14.4 L2 9.5 L9.1 8.6 Z"/></svg><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14.9 8.6 L22 9.5 L16.5 14.4 L18.2 21.5 L12 17.7 L5.8 21.5 L7.5 14.4 L2 9.5 L9.1 8.6 Z"/></svg></span>
