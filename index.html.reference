  <!-- ===================== SECTION 3: WHY REPLACE ===================== -->
  <section class="section bg-white">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(360px, 1fr));gap:56px;align-items:center">
        <div>
          <div class="eyebrow reveal" data-delay="0">Why Convert?</div>
          <h2 class="h-1 reveal" data-delay="0">A conservatory you can <span style="color:var(--orange)">actually use</span> all year round.</h2>
          <div class="reveal" data-delay="120">
            <p class="body-lg" style="margin-top:24px;color:#444">
              Old polycarbonate and glass conservatory roofs are freezing in winter, sweltering in summer and noisy when it rains. A bespoke insulated roof or full conversion fixes all of that — permanently.
            </p>
            <p class="body-lg" style="margin-top:16px;color:#444">
              We specialise in lightweight, energy-saving conservatory roofs. The result: lower heating bills, a quieter room, and a space your family will use every day of the year.
            </p>
          </div>
        </div>
        <div class="reveal" data-delay="150">
          <div class="card-dark card-orange-left">
            <h3 class="h-3" style="color:white;margin-bottom:12px">What you get</h3>
            <ul class="tick-list">
              <li>Superior insulation &amp; thermal performance</li>
              <li>Warm in winter, cool in summer — year-round comfort</li>
              <li>Reduced heating costs and energy bills</li>
              <li>Rain and wind noise eliminated</li>
              <li>Zero maintenance, no leaks or discolouration</li>
            </ul>
            <div style="margin-top:24px;display:inline-flex;align-items:center;gap:10px;background:var(--orange);color:var(--black);padding:10px 18px;border-radius:999px;font-weight:800;text-transform:uppercase;font-family:'iBrand','Outfit',sans-serif;letter-spacing:0.04em">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L13.5 9.5 L21 11 L13.5 12.5 L12 20 L10.5 12.5 L3 11 L10.5 9.5 Z"/></svg> Long-Term Guarantee
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SECTION 4: ROOF OPTIONS PREVIEW ===================== -->
  <section class="section bg-black" style="position:relative">
    <div class="container">
      <div style="text-align:center;max-width:760px;margin:0 auto 56px">
        <div class="eyebrow reveal" data-delay="0">Our Systems</div>
        <h2 class="h-1 reveal" data-delay="0">Multiple Roof Solutions to Suit Every Home</h2>
        <p class="body-lg reveal" data-delay="120" style="margin-top:16px;color:#bbb">
          We aren't tied to one system. We'll recommend what's right for your conservatory — whether that's a solid tiled roof, a hybrid, internal insulation or a full structural conversion.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:20px">
        <div class="reveal" data-delay="0">
          <div class="card-dark" style="height:100%;display:flex;flex-direction:column">
            <svg width="32" height="32" style="color:var(--orange);margin-bottom:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12 L12 4 L21 12"/><path d="M5 12 V20 H19 V12"/></svg>
            <h3 class="h-3" style="color:white">Solid Tiled Roof</h3>
            <p style="color:#bbb;margin-top:10px;font-size:14px;flex:1">Replace your old roof with insulated tiled panels for warmth, quiet and kerb appeal.</p>
            <a href="roof-options.html" style="margin-top:20px;color:white;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;display:inline-flex;align-items:center;gap:6px">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>
        <div class="reveal" data-delay="100">
          <div class="card-dark" style="height:100%;display:flex;flex-direction:column">
            <svg width="32" height="32" style="color:var(--orange);margin-bottom:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
            <h3 class="h-3" style="color:white">Hybrid Roof System</h3>
            <p style="color:#bbb;margin-top:10px;font-size:14px;flex:1">Tiled sections combined with glazed panels for the best of both worlds.</p>
            <a href="roof-options.html" style="margin-top:20px;color:white;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;display:inline-flex;align-items:center;gap:6px">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>
        <div class="reveal" data-delay="200">
          <div class="card-dark" style="height:100%;display:flex;flex-direction:column">
            <svg width="32" height="32" style="color:var(--orange);margin-bottom:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14V4a2 2 0 0 0-4 0v10a4 4 0 1 0 4 0z"/></svg>
            <h3 class="h-3" style="color:white">Internal Insulation</h3>
            <p style="color:#bbb;margin-top:10px;font-size:14px;flex:1">Insulate from the inside in a single day — without changing your exterior.</p>
            <a href="roof-options.html" style="margin-top:20px;color:white;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;display:inline-flex;align-items:center;gap:6px">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>
        <div class="reveal" data-delay="300">
          <div class="card-dark" style="height:100%;display:flex;flex-direction:column">
            <svg width="32" height="32" style="color:var(--orange);margin-bottom:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
            <h3 class="h-3" style="color:white">Full Conversion</h3>
            <p style="color:#bbb;margin-top:10px;font-size:14px;flex:1">A structural conversion that qualifies as a fully-fledged room extension.</p>
            <a href="roof-options.html" style="margin-top:20px;color:white;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:0.06em;display:inline-flex;align-items:center;gap:6px">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>
      </div>

      <div style="text-align:center;margin-top:40px">
        <a href="roof-options.html" class="btn btn-orange">Compare All Options <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
      </div>
