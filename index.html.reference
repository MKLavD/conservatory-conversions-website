          <div class="reveal" data-delay="160" style="margin-top:20px;color:var(--orange);font-size:18px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;font-family:'iBrand','Outfit',sans-serif">
            No Planning Permission Required
          </div>
          <p class="body-lg reveal" data-delay="240" style="margin-top:16px;max-width:580px;color:#cfcfcf">
