<!-- ===================== BROCHURE MODAL ===================== -->
<div class="modal-backdrop" id="brochureBackdrop" style="display:none">
  <div class="modal" id="brochureModal">
    <button class="close-btn" id="brochureCloseBtn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></button>

    <div id="brochureFormView">
      <h3 class="h-2" style="margin-bottom:8px">Get the Free Brochure</h3>
      <p style="color:#666;margin-bottom:24px;font-size:14px">Drop your details below and we'll email it across instantly.</p>
      <form id="brochureForm">
        <div class="field">
          <label>Full Name</label>
          <input required type="text" name="name" placeholder="Jane Smith">
        </div>
        <div class="field">
          <label>Email</label>
          <input required type="email" name="email" placeholder="jane@example.co.uk">
        </div>
        <div class="field">
          <label>Postcode</label>
          <input required type="text" name="postcode" placeholder="KT8 2HT">
        </div>
        <button type="submit" class="btn btn-orange" style="width:100%;padding:16px;margin-top:8px">
          Send Me the Brochure <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
    </div>

    <div id="brochureSuccessView" style="display:none;text-align:center;padding:24px 0">
      <div style="width:64px;height:64px;background:var(--orange);border-radius:999px;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;color:var(--black)">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 class="h-2">Brochure on its way!</h3>
      <p style="color:#666;margin-top:12px">Check your inbox in the next few minutes.</p>
    </div>
  </div>
</div>

